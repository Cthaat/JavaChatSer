# JavaChatSer docker compose defaults.
# Copy to .env only when you need to override ports or credentials.

MYSQL_ROOT_PASSWORD=javachat_root_password
MYSQL_DATABASE=javachat
MYSQL_USER=javachat
MYSQL_PASSWORD=javachat_password

BACKEND_PORT=8080
FRONTEND_PORT=5173

# Must be at least 32 bytes for HS256.
JWT_SECRET=change-this-secret-before-production
JWT_EXPIRATION=86400000

# Leave blank in Docker Compose to use frontend Nginx same-origin proxy.
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
